#!/command/with-contenv sh
cd /rails

# Export internal DB paths for the Rails app
export DB_HOST=127.0.0.1
export DB_PORT=5432
export POSTGRES_USER=sure_user
export POSTGRES_PASSWORD=internal_sure_pass
export POSTGRES_DB=sure_production
export REDIS_URL=redis://127.0.0.1:6379/1

# Wait for postgres
while ! pg_isready -h 127.0.0.1 -U sure_user; do
  sleep 1
done

# Run migrations (safe to run on every boot)
bin/rails db:migrate

rm -f tmp/pids/server.pid
exec bin/rails server -b 0.0.0.0
